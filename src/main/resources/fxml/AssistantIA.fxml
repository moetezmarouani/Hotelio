<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.hotelio.controllers.AssistantIAController"
            style="-fx-background-color: #f5f5f5;">

    <!-- En-tête -->
    <top>
        <VBox spacing="10"
              style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-padding: 20;">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="🤖" style="-fx-font-size: 32px;"/>
                <VBox>
                    <Label text="Assistant IA HotelIO"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Propulsé par Google Gemini"
                           style="-fx-font-size: 12px; -fx-text-fill: #e0e0e0;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="nouveauChatButton"
                        text="🔄 Nouvelle conversation"
                        onAction="#handleNouveauChat"
                        style="-fx-background-color: white; -fx-text-fill: #667eea; -fx-font-weight: bold; -fx-padding: 8 15;"/>
            </HBox>

            <Label text="💬 Posez-moi vos questions sur les chambres, tarifs, services..."
                   style="-fx-text-fill: white; -fx-font-size: 13px;"/>
        </VBox>
    </top>

    <!-- Zone de chat -->
    <center>
        <VBox spacing="10" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <!-- Messages -->
            <ScrollPane fx:id="chatScrollPane"
                        fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox fx:id="chatContainer"
                      spacing="10"
                      style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">

                    <!-- Message de bienvenue -->
                    <VBox spacing="5" alignment="CENTER_LEFT"
                          style="-fx-background-color: #f0f0f0; -fx-padding: 12; -fx-background-radius: 15; -fx-max-width: 450;">
                        <Label text="🤖 Assistant IA"
                               style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #667eea;"/>
                        <Label text="Bonjour ! Je suis votre assistant virtuel. Comment puis-je vous aider à trouver la chambre parfaite pour votre séjour ?"
                               wrapText="true"
                               style="-fx-font-size: 14px; -fx-text-fill: black;"/>
                    </VBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>

    <!-- Zone de saisie -->
    <bottom>
        <VBox spacing="10"
              style="-fx-background-color: white; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, -2);">

            <!-- Suggestions rapides -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="💡 Suggestions:"
                       style="-fx-font-size: 11px; -fx-text-fill: gray;"/>
                <Button text="Chambre pour couple"
                        onAction="#handleSuggestion1"
                        style="-fx-background-color: #e8eaf6; -fx-text-fill: #667eea; -fx-font-size: 11px; -fx-padding: 5 10; -fx-background-radius: 15;"/>
                <Button text="Budget &lt; 150 DT"
                        onAction="#handleSuggestion2"
                        style="-fx-background-color: #e8eaf6; -fx-text-fill: #667eea; -fx-font-size: 11px; -fx-padding: 5 10; -fx-background-radius: 15;"/>
                <Button text="Suite familiale"
                        onAction="#handleSuggestion3"
                        style="-fx-background-color: #e8eaf6; -fx-text-fill: #667eea; -fx-font-size: 11px; -fx-padding: 5 10; -fx-background-radius: 15;"/>
            </HBox>

            <!-- Zone de texte et bouton -->
            <HBox spacing="10" alignment="CENTER">
                <TextArea fx:id="messageInput"
                          promptText="Tapez votre question ici... (Ex: Je cherche une chambre pour 2 personnes avec un budget de 150 DT)"
                          wrapText="true"
                          prefRowCount="2"
                          HBox.hgrow="ALWAYS"
                          style="-fx-font-size: 14px; -fx-border-color: #e0e0e0; -fx-border-radius: 10; -fx-background-radius: 10;"/>

                <VBox spacing="5" alignment="CENTER">
                    <Button fx:id="envoyerButton"
                            text="📤 Envoyer"
                            onAction="#handleEnvoyer"
                            defaultButton="true"
                            style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 10; -fx-cursor: hand;"/>
                    <Label fx:id="statusLabel"
                           text="Prêt"
                           style="-fx-font-size: 10px; -fx-text-fill: gray;"/>
                </VBox>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>