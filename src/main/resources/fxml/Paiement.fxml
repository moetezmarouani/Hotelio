<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.hotelio.controllers.PaiementController"
      spacing="20"
      style="-fx-background-color: #f5f5f5;"
      prefWidth="500"
      prefHeight="600">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- En-tête -->
    <VBox spacing="10"
          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">
        <Label text="💳 Paiement Sécurisé"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Label fx:id="montantLabel"
               text="Montant à payer: 0.00 DT"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
    </VBox>

    <!-- Informations carte -->
    <VBox spacing="15"
          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">

        <Label text="Informations de carte bancaire"
               style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

        <Separator/>

        <VBox spacing="5">
            <Label text="Numéro de carte *" style="-fx-font-weight: bold;"/>
            <TextField fx:id="numeroCarteField"
                       promptText="1234 5678 9012 3456"
                       maxWidth="Infinity"/>
            <Label fx:id="carteTypeLabel"
                   text=""
                   style="-fx-text-fill: #3498db; -fx-font-size: 12px;"/>
        </VBox>

        <VBox spacing="5">
            <Label text="Titulaire de la carte *" style="-fx-font-weight: bold;"/>
            <TextField fx:id="nomTitulaireField"
                       promptText="NOM PRENOM"
                       maxWidth="Infinity"/>
        </VBox>

        <HBox spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Date d'expiration *" style="-fx-font-weight: bold;"/>
                <HBox spacing="5">
                    <ComboBox fx:id="moisComboBox"
                              promptText="Mois"
                              prefWidth="100"/>
                    <ComboBox fx:id="anneeComboBox"
                              promptText="Année"
                              prefWidth="100"/>
                </HBox>
            </VBox>

            <VBox spacing="5">
                <Label text="CVV *" style="-fx-font-weight: bold;"/>
                <TextField fx:id="cvvField"
                           promptText="123"
                           prefWidth="80"/>
                <Label text="🛡️ Code au dos"
                       style="-fx-font-size: 10px; -fx-text-fill: gray;"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- Sécurité -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: #e8f5e9; -fx-padding: 15; -fx-background-radius: 5;">
        <Label text="🔒" style="-fx-font-size: 20px;"/>
        <VBox>
            <Label text="Paiement 100% sécurisé"
                   style="-fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
            <Label text="Vos données sont cryptées et protégées"
                   style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
        </VBox>
    </HBox>

    <!-- Boutons -->
    <HBox spacing="10">
        <Button fx:id="payerButton"
                text="💳 Payer maintenant"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12 20; -fx-cursor: hand;"
                HBox.hgrow="ALWAYS"
                maxWidth="Infinity"/>

        <Button fx:id="annulerButton"
                text="Annuler"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12 20;"
                prefWidth="120"/>
    </HBox>

    <!-- Footer -->
    <HBox spacing="10" alignment="CENTER">
        <Label text="🔒 SSL" style="-fx-font-size: 10px; -fx-text-fill: gray;"/>
        <Label text="•" style="-fx-text-fill: gray;"/>
        <Label text="PCI DSS Compliant" style="-fx-font-size: 10px; -fx-text-fill: gray;"/>
        <Label text="•" style="-fx-text-fill: gray;"/>
        <Label text="Visa, Mastercard acceptés" style="-fx-font-size: 10px; -fx-text-fill: gray;"/>
    </HBox>

</VBox>