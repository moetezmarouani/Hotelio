<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.hotelio.controllers.MonProfilController"
            fitToWidth="true"
            fitToHeight="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED">

    <content>
        <VBox spacing="20.0"
              style="-fx-background-color: #f5f5f5;"
              prefWidth="600">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- Titre -->
            <Label text="👤 Mon Profil"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <!-- Informations personnelles -->
            <VBox spacing="15"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">

                <Label text="Informations personnelles"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                <Separator/>

                <GridPane hgap="15" vgap="15">
                    <Label text="Nom:" GridPane.columnIndex="0" GridPane.rowIndex="0"
                           style="-fx-font-weight: bold;"/>
                    <TextField fx:id="nomField" GridPane.columnIndex="1" GridPane.rowIndex="0"
                               prefWidth="300"/>

                    <Label text="Prénom:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                           style="-fx-font-weight: bold;"/>
                    <TextField fx:id="prenomField" GridPane.columnIndex="1" GridPane.rowIndex="1"
                               prefWidth="300"/>

                    <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="2"
                           style="-fx-font-weight: bold;"/>
                    <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="2"
                               prefWidth="300"/>

                    <Label text="Téléphone:" GridPane.columnIndex="0" GridPane.rowIndex="3"
                           style="-fx-font-weight: bold;"/>
                    <TextField fx:id="telephoneField" GridPane.columnIndex="1" GridPane.rowIndex="3"
                               prefWidth="300"/>

                    <Label text="Membre depuis:" GridPane.columnIndex="0" GridPane.rowIndex="4"
                           style="-fx-font-weight: bold;"/>
                    <Label fx:id="dateCreationLabel" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                </GridPane>

                <HBox spacing="10">
                    <Button fx:id="updateButton"
                            text="💾 Enregistrer les modifications"
                            onAction="#handleUpdate"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 10 20;"/>

                    <Button fx:id="cancelButton"
                            text="❌ Annuler"
                            onAction="#handleCancel"
                            style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-padding: 10 20;"/>
                </HBox>
            </VBox>

            <!-- Changer mot de passe -->
            <VBox spacing="15"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">

                <Label text="Changer le mot de passe"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                <Separator/>

                <GridPane hgap="15" vgap="15">
                    <Label text="Ancien mot de passe:" GridPane.columnIndex="0" GridPane.rowIndex="0"
                           style="-fx-font-weight: bold;"/>
                    <PasswordField fx:id="oldPasswordField" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                   prefWidth="300"/>

                    <Label text="Nouveau mot de passe:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                           style="-fx-font-weight: bold;"/>
                    <PasswordField fx:id="newPasswordField" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                   prefWidth="300"/>

                    <Label text="Confirmer le nouveau:" GridPane.columnIndex="0" GridPane.rowIndex="2"
                           style="-fx-font-weight: bold;"/>
                    <PasswordField fx:id="confirmPasswordField" GridPane.columnIndex="1" GridPane.rowIndex="2"
                                   prefWidth="300"/>
                </GridPane>

                <Button fx:id="changePasswordButton"
                        text="🔐 Changer le mot de passe"
                        onAction="#handleChangePassword"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 10 20;"/>
            </VBox>

            <!-- Statistiques -->
            <VBox spacing="15"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">

                <Label text="📊 Mes statistiques"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                <Separator/>

                <GridPane hgap="30" vgap="15">
                    <VBox GridPane.columnIndex="0" GridPane.rowIndex="0"
                          spacing="5" alignment="CENTER"
                          style="-fx-background-color: #3498db; -fx-padding: 20; -fx-background-radius: 10;">
                        <Label fx:id="totalReservationsLabel"
                               text="0"
                               style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Réservations totales"
                               style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox GridPane.columnIndex="1" GridPane.rowIndex="0"
                          spacing="5" alignment="CENTER"
                          style="-fx-background-color: #27ae60; -fx-padding: 20; -fx-background-radius: 10;">
                        <Label fx:id="totalNuitsLabel"
                               text="0"
                               style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Nuits passées"
                               style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox GridPane.columnIndex="2" GridPane.rowIndex="0"
                          spacing="5" alignment="CENTER"
                          style="-fx-background-color: #f39c12; -fx-padding: 20; -fx-background-radius: 10;">
                        <Label fx:id="totalDepenseLabel"
                               text="0 DT"
                               style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Total dépensé"
                               style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    </VBox>
                </GridPane>
            </VBox>

            <!-- Programme de Fidélité -->
            <VBox spacing="15"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">

                <Label text="💎 Programme de Fidélité"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                <Separator/>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <VBox spacing="5" alignment="CENTER"
                          style="-fx-padding: 15; -fx-background-radius: 10; -fx-min-width: 150;">
                        <Label fx:id="niveauLabel"
                               text="🥉 BRONZE"
                               style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                        <Label text="Votre niveau"
                               style="-fx-font-size: 12px; -fx-text-fill: gray;"/>
                    </VBox>

                    <VBox spacing="5" alignment="CENTER"
                          style="-fx-background-color: #f39c12; -fx-padding: 15; -fx-background-radius: 10; -fx-min-width: 150;">
                        <Label fx:id="pointsLabel"
                               text="0"
                               style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Points"
                               style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox spacing="5" alignment="CENTER"
                          style="-fx-background-color: #27ae60; -fx-padding: 15; -fx-background-radius: 10; -fx-min-width: 150;">
                        <Label fx:id="reductionLabel"
                               text="0%"
                               style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Réduction"
                               style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>

                <VBox spacing="10">
                    <Label fx:id="prochainNiveauLabel"
                           text="Plus que 1000 points pour atteindre SILVER"
                           style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>

                    <ProgressBar fx:id="progressBar"
                                 progress="0"
                                 prefWidth="Infinity"
                                 style="-fx-accent: #f39c12;"/>
                </VBox>

                <Label text="Avantages du programme :"
                       style="-fx-font-weight: bold; -fx-font-size: 14px;"/>

                <GridPane hgap="10" vgap="5">
                    <Label text="🥉 BRONZE" GridPane.columnIndex="0" GridPane.rowIndex="0"
                           style="-fx-font-weight: bold;"/>
                    <Label text="0% de réduction" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="🥈 SILVER (1000+ pts)" GridPane.columnIndex="0" GridPane.rowIndex="1"
                           style="-fx-font-weight: bold;"/>
                    <Label text="5% de réduction" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="🥇 GOLD (3000+ pts)" GridPane.columnIndex="0" GridPane.rowIndex="2"
                           style="-fx-font-weight: bold;"/>
                    <Label text="10% de réduction" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="💎 PLATINUM (5000+ pts)" GridPane.columnIndex="0" GridPane.rowIndex="3"
                           style="-fx-font-weight: bold;"/>
                    <Label text="15% de réduction" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                </GridPane>
            </VBox>

        </VBox>
    </content>
</ScrollPane>